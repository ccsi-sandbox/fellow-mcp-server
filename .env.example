# Fellow.ai API Configuration (Required)
FELLOW_API_KEY=your-fellow-api-key-here
FELLOW_SUBDOMAIN=your-company

# MCP Authentication (Optional)
# Set MCP_AUTH_ENABLED to "true" (case-sensitive) to require token auth
MCP_AUTH_ENABLED=false
# Token must be at least 16 characters when auth is enabled
MCP_AUTH_TOKEN=your-secure-token-here-min-16-chars

# Server Configuration
# Integer 1-8, default: 2
GUNICORN_WORKERS=2
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# MCP Endpoint Configuration
# Default: /mcp
MCP_ENDPOINT_PATH=/mcp

# Timezone Configuration
# Container timezone (IANA format). Default: America/Los_Angeles
TZ=America/Los_Angeles
